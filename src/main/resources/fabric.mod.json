  "authors": ["nnpg"],
  "contact": {
    "homepage": "https://meteorplusplusclient.com",
    "repo": "https://github.com/realnnpg/",
    "discord": "https://discord.gg/meteorplusplus"
  },
  "license": "All Rights Reserved",
  "icon": "assets/template/icon.png",
